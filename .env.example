# ═══════════════════════════════════════════════════════════
# ZonAlert Backend — Variables d'environnement
# Copier : cp .env.example .env  puis renseigner les valeurs
# ═══════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000
APP_NAME=ZonAlert Backend

# ── Base de données ────────────────────────────────────────
# Option A : URL complète (Railway la fournit automatiquement)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Option B : variables individuelles (développement local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=290897
DB_NAME=zonalert_db
DB_SYNC=true
DB_LOGGING=true

# ── JWT ───────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=changez_cette_cle_en_production_minimum_32_chars
JWT_REFRESH_SECRET=autre_cle_differente_en_production_minimum_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8100,http://localhost:4200,capacitor://localhost

# ── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Firebase Admin SDK (optionnel) ────────────────────────
# Obtenir depuis : console.firebase.google.com → Comptes de service
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
